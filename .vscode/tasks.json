{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Next.js Dev",
      "type": "shell",
      "command": "./node_modules/.bin/next dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Ready in .*|ready - started server on .*|Local:\\s+http://localhost:3000"
        }
      }
    }
  ]
}
