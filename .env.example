# ─── AI Provider ───────────────────────────────────────────
# Option A: OpenAI (paid)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Option B: Groq (FREE - 14,400 requests/day)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# Option C: Ollama (FREE - runs locally)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Which provider to use: openai | groq | ollama | free
NEXA_AI_PROVIDER=groq

# ─── Cloudinary (FREE 25GB - file storage) ─────────────────
# Sign up at cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Supabase (FREE database) ──────────────────────────────
# Sign up at supabase.com → New project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# ─── Server ────────────────────────────────────────────────
BACKEND_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# In production set this to your Railway backend URL:
# NEXT_PUBLIC_API_BASE_URL=https://your-app.railway.app/api

# ─── Frontend URL (for CORS) ───────────────────────────────
FRONTEND_URL=http://localhost:3000
# In production: FRONTEND_URL=https://your-app.vercel.app
